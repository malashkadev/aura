{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura",
  "version": "1.0.7",
  "identifier": "com.aura.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Настройки Aura",
        "url": "index.html",
        "width": 760,
        "height": 550,
        "minWidth": 760,
        "minHeight": 550,
        "resizable": true,
        "visible": true,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 160,
        "height": 80,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "focusable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4RjBCODU2OUNDNDAwMjkKUldRcEFNU2NWcmp3U1A0b2NQVVJTVkhXMkc2UWEwRzYxSzJVVmd5Z0NUcUpucDVhbFBLcm9BOXIK",
      "endpoints": [
        "https://github.com/malashkadev/aura/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/*.dll",
      "binaries/sherpa-onnx-offline-websocket-server.exe",
      "binaries/sherpa-onnx-offline-punctuation.exe"
    ],
    "externalBin": [
      "binaries/whisper-sidecar",
      "binaries/sherpa-onnx-offline"
    ]
  }
}
