{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura",
  "version": "0.1.0",
  "identifier": "com.aura.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Настройки Aura",
        "url": "index.html",
        "width": 700,
        "height": 550,
        "resizable": false,
        "visible": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 160,
        "height": 60,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/whisper-sidecar"
    ]
  }
}
