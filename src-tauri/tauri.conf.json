{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura",
  "version": "2.0.0",
  "identifier": "com.aura.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Настройки Aura",
        "url": "index.html",
        "width": 700,
        "height": 550,
        "resizable": false,
        "visible": true,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 160,
        "height": 80,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "focusable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/*.dll"
    ],
    "externalBin": [
      "binaries/whisper-sidecar"
    ]
  }
}
