# Ignore binary executables (whisper sidecar in src-tauri/binaries is intentionally tracked)
Aura.exe
*.exe
!src-tauri/binaries/*.exe
!website/*.exe

# Ignore node_modules
node_modules/

# Ignore Rust build artifacts
target/

# Ignore local config/databases
*.db
*.db-shm
*.db-wal
.window-state.json
settings.json

# AI-tooling working files (not part of the app)
.agents/
.impeccable/
.superdesign/
graphify-out/
.graphifyignore
skills-lock.json
docs/superpowers/
test_out.txt
/Logo DARK.png
DESIGN.md
PRODUCT.md

.vercel
.env*

# Never commit signing private keys
*.key
*.pem
minisign*
